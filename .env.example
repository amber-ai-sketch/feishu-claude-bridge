# feishu-claude-bridge 环境变量模板
# 复制成 .env 并填真值（.env 已在 .gitignore 里）：
#   cp .env.example .env
#
# 或者直接 export 到 shell，bridge.ts 从 process.env 读。

# ────────────────────────────────────────────────
# 必填
# ────────────────────────────────────────────────

# 你的飞书 open_id 白名单（逗号分隔支持多个，只有白名单内的人发消息才会触发 Claude）
# 拿 open_id 的方法见 README「Step 0.3」
# 示例：ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FCB_OWNER_OPEN_IDS=

# Anthropic API key（claude CLI 用，不是 bridge 直接读）
# 如果你走第三方 provider，改下面的 ANTHROPIC_BASE_URL
ANTHROPIC_API_KEY=

# ────────────────────────────────────────────────
# 可选
# ────────────────────────────────────────────────

# 默认模型 alias（opus / sonnet / haiku），或者完整 model id
# 每个飞书频道可以用 /model 元指令单独覆盖
# FCB_CLAUDE_MODEL=opus

# bridge 状态目录（sessions.json / crontab.json / chat-models.json 落盘位置）
# 默认 $HOME/.local/state/fcb
# FCB_STATE_DIR=

# lark-cli 可执行路径（默认 lark-cli，假设在 PATH 里）
# 本地测试想跑 fake-event.ts 可以把这个指过去
# FCB_LARK_CLI=lark-cli

# claude CLI 可执行路径（默认 claude，假设在 PATH 里）
# 如果 `which claude` 找不到，或者 symlink 指向了 .exe（VSCode extension 那种坑），这里写绝对路径
# FCB_CLAUDE_CLI=/opt/homebrew/bin/claude

# 第三方 Anthropic-compatible provider base URL
# 走官方 API 不用管这个
# ANTHROPIC_BASE_URL=https://your-provider.example.com/anthropic

# 第三方 provider 的 model id 映射（Claude Code 支持）
# 当 --model opus/sonnet/haiku 别名进来时解析成下面的实际 id
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
