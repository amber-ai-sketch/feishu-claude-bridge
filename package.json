{
  "name": "feishu-claude-bridge",
  "version": "0.1.0",
  "description": "Feishu <-> Claude Code CLI bridge (bot-only, single-user, bypass permissions)",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run bridge.ts",
