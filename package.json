    "typecheck": "tsc --noEmit",
    "fake-event": "bun run fake-event.ts"
  },
  "dependencies": {
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  }
}
